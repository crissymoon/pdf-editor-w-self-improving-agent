{
  "name": "xcm-pdf",
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "bin": {
    "xcm": "xcm_cli/xcm.mjs"
  },
  "type": "module",
  "description": "XCM-PDF Editor - Developed for Leto's Angels Educational Project by XcaliburMoon Web Development",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate-example": "node generate-example-pdf.js",
    "pdf-tests:generate": "node pdf_tests/generate-random-pdfs.mjs",
    "pdf-tests:generate:quick": "node pdf_tests/generate-random-pdfs.mjs --count=10 --min-pages=1 --max-pages=4",
    "review": "node code_review/scripts/run-all.mjs",
    "review:strict": "node code_review/scripts/run-all.mjs",
    "review:advisory": "cross-env REVIEW_PROFILE=advisory node code_review/scripts/run-all.mjs",
    "review:eslint": "node code_review/scripts/check-eslint.mjs",
    "review:ruff": "node code_review/scripts/check-ruff.mjs",
    "review:go-lint": "node code_review/scripts/check-go-lint.mjs",
    "review:smoke": "node code_review/scripts/smoke-test.mjs",
    "review:smells": "node code_review/scripts/check-code-smells.mjs",
    "review:security": "node code_review/scripts/check-security.mjs",
    "review:lines": "node code_review/scripts/check-file-lines.mjs",
    "review:go": "node code_review/scripts/check-go-funcs.mjs",
    "review:pdo-pep": "node code_review/scripts/check-pdo-pep-templating.mjs",
    "review:complexity": "node code_review/scripts/check-complexity.mjs",
    "review:performance": "node code_review/scripts/check-performance-memory.mjs",
    "review:server": "node code_review/scripts/check-server-readiness.mjs",
    "agent:promote": "node scripts/agent/promote-dbl-to-main.mjs",
    "agent:status": "node scripts/agent/checkin.mjs",
    "agent:status:strict": "node scripts/agent/checkin.mjs --strict",
    "agent:readme:generate": "node scripts/agent/generate-readme-folder-updates.mjs",
    "agent:checkin": "npm run review:advisory && npm run agent:readme:generate && npm run agent:status",
    "agent:checkin:strict": "npm run review:strict && npm run agent:readme:generate && npm run agent:status:strict",
    "xcm": "node xcm_cli/xcm.mjs",
    "xcm:help": "node xcm_cli/xcm.mjs help",
    "dev:electron": "concurrently -k \"vite --port 5173 --strictPort\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron": "electron .",
    "pack": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
    "pack:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --publish never",
    "pack:mac": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --publish never",
    "pack:linux": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux AppImage --publish never",
    "push:shared": "node scripts/git/push-shared-repos.mjs --auto-commit",
    "sync:shared": "node scripts/git/push-shared-repos.mjs",
    "sync:shared:auto": "node scripts/git/push-shared-repos.mjs --auto-commit",
    "docker:test:linux": "docker compose -f docker/docker-compose.electron.yml --profile linux run --rm electron-linux",
    "docker:test:windows": "docker compose -f docker/docker-compose.electron.yml --profile windows run --rm electron-windows",
    "docker:test:macos": "docker compose -f docker/docker-compose.electron.yml --profile macos run --rm electron-macos-check",
    "mcp:smoke:live": "node mcp/scripts/live-smoke-openai.mjs",
    "mcp:smoke:live:strict": "node mcp/scripts/live-smoke-openai.mjs --strict",
    "mcp:browser:install": "npm --prefix mcp/browser_tools install",
    "mcp:browser:install:browsers": "npm --prefix mcp/browser_tools run install:browsers",
    "mcp:browser:smoke:playwright": "npm --prefix mcp/browser_tools run smoke:playwright",
    "mcp:browser:smoke:puppeteer": "npm --prefix mcp/browser_tools run smoke:puppeteer",
    "mcp:smoke:browser:mcp": "node mcp/scripts/browser-tooling-smoke.mjs",
    "mcp:smoke:file-tools": "node mcp/scripts/file-tools-smoke.mjs",
    "review:wcag": "node code_review/scripts/check-wcag-colors.mjs",
    "mobile:get": "cd mobile && flutter pub get",
    "mobile:run": "cd mobile && flutter run",
    "mobile:build:android": "cd mobile && flutter build apk --release",
    "mobile:build:ios": "cd mobile && flutter build ipa --release",
    "mock:smoke": "node mock_model_smoke/src/index.mjs smoke",
    "mock:simulate": "node mock_model_smoke/src/index.mjs simulate --scenario mock_model_smoke/scenarios/default-scenario.json",
    "mock:run": "node mock_model_smoke/src/index.mjs run",
    "mock:simulate:pdf": "node mock_model_smoke/src/index.mjs simulate --config mock_model_smoke/config/pdf-scenario.config.json --scenario mock_model_smoke/scenarios/pdf-editor-scenario.json --target-file mock_model_smoke/fixtures/pdf-editor-workflow.fixture.ts",
    "mock:simulate:mcp": "node mock_model_smoke/src/index.mjs simulate --config mock_model_smoke/config/mcp-json.config.json --scenario mock_model_smoke/scenarios/mcp-json-scenario.json --target-file mock_model_smoke/fixtures/mcp-workflow.fixture.ts --parser json-edit",
    "mock:file-worker:smoke": "node mock_model_smoke/scripts/file-worker-mcp-smoke.mjs",
    "mock:evaluate": "node mock_model_smoke/scripts/test-pdf-mcp-tooling.mjs",
    "mock:evaluate:stress": "node mock_model_smoke/scripts/test-pdf-mcp-tooling.mjs",
    "mock:evaluate:stress:constrained": "node mock_model_smoke/scripts/test-pdf-mcp-tooling.mjs --stress-profile constrained",
    "mock:evaluate:stress:high": "node mock_model_smoke/scripts/test-pdf-mcp-tooling.mjs --stress-profile high-throughput",
    "mock:evaluate:ci": "npm run mock:smoke && node mock_model_smoke/scripts/test-pdf-mcp-tooling.mjs --skip-live-mcp --stress-profile constrained && node mock_model_smoke/scripts/test-pdf-mcp-tooling.mjs --skip-live-mcp --stress-profile high-throughput"
  },
  "keywords": [
    "pdf",
    "editor",
    "digital-signature",
    "education"
  ],
  "author": "XcaliburMoon Web Development",
  "license": "MIT",
  "build": {
    "appId": "org.letosangels.xcm-pdf",
    "productName": "XCM-PDF Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "@types/node": "^25.0.2",
    "fabric": "^7.2.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.449",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.7.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.28.0",
    "wait-on": "^8.0.5"
  }
}
