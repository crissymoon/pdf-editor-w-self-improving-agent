    {
      "id": "req-4",
      "prompt": "delete line 2 in ${TARGET_FILE}",
      "expectSuccess": true
    },
    {
      "id": "req-5",
      "prompt": "replace text \"featureFlagEnabled\" with \"isFeatureFlagEnabled\" in ${TARGET_FILE}",
      "expectSuccess": true
